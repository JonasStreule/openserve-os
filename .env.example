# ─────────────────────────────────────────────────────────
# OpenServe OS — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://dev:dev123@localhost:5432/openserve

# Redis
REDIS_URL=redis://localhost:6379

# Auth — generate with: openssl rand -base64 40
JWT_SECRET=change-me-in-production

# Server
PORT=3000
NODE_ENV=development

# JWT expiry — use 8h for personal logins, 24h for station devices
JWT_EXPIRY=8h

# CORS — comma-separated list of allowed frontend origins
# Leave empty in development (allows all). Required in production.
CORS_ORIGIN=https://pos.yourrestaurant.ch

# ── Sentry (optional — leave blank to disable) ─────────────
# Create a project at https://sentry.io and paste the DSN here
SENTRY_DSN=

# Frontend (set in frontend/.env)
# VITE_API_URL=http://localhost:3000
# VITE_SENTRY_DSN=
